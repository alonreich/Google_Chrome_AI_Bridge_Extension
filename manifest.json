{
    "manifest_version": 3,
    "name": "Google Chrome Bridge",
    "version": "1.5.14",
    "description": "Local HTTP bridge: exposes live Chrome tabs to AI via localhost:5000.",
    "permissions": [
        "storage",
        "tabs",
        "scripting",
        "activeTab",
        "webNavigation",
        "alarms"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon_16.png",
            "48": "icons/icon_48.png",
            "128": "icons/icon_128.png"
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "icons": {
        "16": "icons/icon_16.png",
        "48": "icons/icon_48.png",
        "128": "icons/icon_128.png"
    }
}
